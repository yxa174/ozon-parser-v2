# Ozon Parser v2 — Конфигурация

# Путь к SQLite базе
DB_PATH=ozon_data.db

# Воркеры
MAX_WORKERS=5

# Задержки между запросами (секунды)
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=4.0

# Таймаут запроса (секунды)
REQUEST_TIMEOUT=30

# Максимум повторных попыток
MAX_RETRIES=3

# Прокси
USE_PROXY_ROTATION=true
PROXY_FILE=proxies.txt

# Рандомизация фингерпринта
RANDOMIZE_FINGERPRINT=true

# Ozon Seller API (опционально)
OZON_API_ENABLED=false
OZON_API_KEY=
OZON_CLIENT_ID=

# Браузер fallback (Playwright)
USE_BROWSER=false

# Файлы
URLS_FILE=urls.txt
EXPORT_DIR=exports
